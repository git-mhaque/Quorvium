# Server configuration
PORT=4000
CLIENT_ORIGIN=http://localhost:5173
DATA_STORE=file

# Firestore persistent datastore (used when DATA_STORE=firestore)
# Leave FIRESTORE_PROJECT_ID empty to use Application Default Credentials project resolution.
FIRESTORE_PROJECT_ID=
# Optional; defaults to "(default)" when omitted.
FIRESTORE_DATABASE_ID=
# Optional collection name override for board documents.
FIRESTORE_BOARDS_COLLECTION=boards

# Google OAuth verification
# Obtain from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5173/
