project_id            = "your-gcp-project-id"
region                = "us-central1"
environment           = "staging"
service_name          = "quorvium-api"
cloud_run_max_instances = 5
cloud_run_cpu         = "1"
cloud_run_memory      = "512Mi"
oauth_client_secret_secret_id = "google-oauth-client-secret"
# Optional override; normally not needed because `cloud_run_image` has a default bootstrap image.
# cloud_run_image       = "us-central1-docker.pkg.dev/PROJECT/REPO/quorvium-api:BOOTSTRAP_TAG_OR_DIGEST"
enable_firestore_database = true
firestore_location        = "australia-southeast1"
firestore_database_name   = "(default)"
